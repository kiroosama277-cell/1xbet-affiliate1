generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SalesRef {
  id        String    @id @default(cuid())
  code      String    @unique
  name      String
  email     String?
  phone     String?
  target    Int       @default(50)
  isActive  Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  registrations Registration[]
  commissions  Commission[]
  activities   ActivityLog[]
}

model Registration {
  id            String    @id @default(cuid())
  name          String
  email         String
  phone         String
  country       String
  promoCode     String
  trafficSource String
  channelDesc   String?
  refCode       String?
  salesRefId    String?
  status        String    @default("new")
  notes         String?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  salesRef    SalesRef?      @relation(fields: [salesRefId], references: [id])
  commissions Commission[]
}

model Commission {
  id             String    @id @default(cuid())
  salesRefId     String
  registrationId String
  amount         Float     @default(0)
  currency       String    @default("USD")
  status         String    @default("pending")
  month          String
  paidAt         DateTime?
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())

  salesRef      SalesRef      @relation(fields: [salesRefId], references: [id])
  registration  Registration  @relation(fields: [registrationId], references: [id])
}

model ActivityLog {
  id         String   @id @default(cuid())
  action     String
  details    String?
  salesRefId String?
  createdAt  DateTime @default(now())

  salesRef SalesRef? @relation(fields: [salesRefId], references: [id])
}

model Admin {
  id         String   @id @default(cuid())
  username   String   @unique
  accessCode String
  createdAt  DateTime @default(now())
}

model Settings {
  id    String @id @default(cuid())
  key   String @unique
  value String
}
